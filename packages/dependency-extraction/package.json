{
  "name": "vite-plugin-wordpress-dependency-extraction",
  "version": "0.1.0",
  "description": "Vite Plugin for WordPress Dependency Extraction",
  "keywords": [
    "wordpress",
    "wordpress-dependency-extraction",
    "vite",
    "vite-plugin"
  ],
  "homepage": "https://github.com/paulomfr/vite-plugin-wordpress/tree/HEAD/packages/dependency-extraction/README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paulomfr/vite-plugin-wordpress.git",
    "directory": "packages/dependency-extraction"
  },
  "bugs": {
    "url": "https://github.com/paulomfr/vite-plugin-wordpress/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Paulo Ferreira",
    "email": "paulo@collaborar.com"
  },
  "engines": {
    "node": ">= 20"
  },
  "files": [
    "build-module",
    "build-types",
    "*.md"
  ],
  "type": "module",
  "module": "build-module/index.mjs",
  "types": "build-types",
  "exports": {
    ".": {
      "types": "./build-types/index.d.ts",
      "import": "./build-module/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "start": "pnpx concurrently -c \"#ffcf00,#3178c6\" \"pnpm start:build\" \"pnpm start:types\" --names build,types",
    "start:build": "./esbuild.js --watch",
    "start:types": "tsc --watch --preserveWatchOutput",
    "build:types": "tsc"
  },
  "dependencies": {
    "change-case": "^5.4.4",
    "es-module-lexer": "^2.0.0",
    "magic-string": "^0.30.21"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  }
}
