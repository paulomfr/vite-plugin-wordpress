{
  "name": "vite-plugin-wordpress",
  "version": "0.1.0",
  "description": "Vite Plugin for WordPress",
  "keywords": [
    "wordpress",
    "vite",
    "vite-plugin"
  ],
  "license": "MIT",
  "author": {
    "name": "Paulo Ferreira",
    "email": "paulo@collaborar.com"
  },
  "engines": {
    "node": ">= 20"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "/dist"
  ],
  "scripts": {
    "dev": "esbuild src/index.ts --platform=node --format=esm --bundle --outfile=dist/index.js --packages=external --watch",
    "build": "rm -rf dist && pnpm run build-types && pnpm run build-plugin-esm",
    "build-types": "tsc",
    "build-plugin-esm": "esbuild src/index.ts --platform=node --format=esm --bundle --outfile=dist/index.js --packages=external"
  }
}
