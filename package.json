{
  "name": "vite-plugin-wordpress",
  "version": "0.1.0",
  "description": "Vite Plugin for WordPress",
  "keywords": [
    "wordpress",
    "vite",
    "vite-plugin"
  ],
  "homepage": "https://github.com/paulomfr/vite-plugin-wordpress/tree/HEAD/README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paulomfr/vite-plugin-wordpress.git",
    "directory": "packages/dependency-extraction"
  },
  "bugs": {
    "url": "https://github.com/paulomfr/vite-plugin-wordpress/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Paulo Ferreira",
    "email": "paulo@collaborar.com"
  },
  "engines": {
    "node": ">= 20"
  },
  "files": [
    "build-module",
    "build-types",
    "*.md"
  ],
  "type": "module",
  "module": "build-module/index.mjs",
  "types": "build-types",
  "exports": {
    ".": {
      "types": "./build-types/index.d.ts",
      "import": "./build-module/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "pnpm clean && ./esbuild.js && tsc",
    "clean": "rimraf --glob \"./{build,build-module,build-types}\"",
    "start": "pnpx concurrently -c \"#ffcf00,#3178c6\" \"pnpm watch-plugin\" \"pnpm watch-types\" --names plugin,types",
    "watch-plugin": "./esbuild.js --watch",
    "watch-types": "tsc --preserveWatchOutput --watch"
  },
  "dependencies": {
    "change-case": "^5.4.4",
    "es-module-lexer": "^2.0.0",
    "magic-string": "^0.30.21"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  }
}
