{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "target": "esnext",
    "module": "preserve",
    "moduleResolution": "bundler",
    "lib": [ "DOM", "DOM.Iterable", "ESNext" ],
    "resolveJsonModule": true,
    "strict": true,
    "declaration": true,
    "esModuleInterop": true
  },
  "include": [
    "./src"
  ]
}
